FROM php:8.2-apache

# Installer les extensions PHP nécessaires
RUN apt-get update && apt-get install -y \
    libzip-dev \
    zip \
    unzip \
    && docker-php-ext-install pdo pdo_mysql \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Installer Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Activer mod_rewrite
RUN a2enmod rewrite

# Configurer Apache pour Railway
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf
RUN echo "Listen \${PORT}" > /etc/apache2/ports.conf
RUN sed -i 's/:80/:${PORT}/g' /etc/apache2/sites-available/000-default.conf

# Config Apache pour index.php
RUN echo '<Directory /var/www/html> \
  DirectoryIndex index.php \
  AllowOverride All \
  Require all granted \
</Directory>' > /etc/apache2/conf-available/php.conf && \
a2enconf php

# Configuration du document root
ENV APACHE_DOCUMENT_ROOT /var/www/html/src
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

# Configuration des permissions
RUN chown -R www-data:www-data /var/www/html \
    && chmod -R 755 /var/www/html

# Copier les fichiers
WORKDIR /var/www/html
COPY composer.json composer.lock* ./
RUN composer install --no-dev --no-interaction --optimize-autoloader --ignore-platform-req=ext-mysqli

COPY . .

# Configuration finale des permissions
RUN chown -R www-data:www-data /var/www/html \
    && find /var/www/html -type f -exec chmod 644 {} \; 2>/dev/null || true \
    && find /var/www/html -type d -exec chmod 755 {} \; 2>/dev/null || true

# Railway utilise la variable PORT
CMD sed -i "s/80/${PORT}/g" /etc/apache2/sites-available/000-default.conf && apache2-foreground