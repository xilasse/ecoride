# Dockerfile de test optimisé pour Railway avec MySQL
FROM php:8.2-apache

# Installation des outils essentiels
RUN apt-get update && apt-get install -y \
    default-mysql-client \
    netcat-openbsd \
    curl \
    gettext-base \
    && rm -rf /var/lib/apt/lists/*

# Installation des extensions PHP nécessaires
RUN docker-php-ext-install pdo pdo_mysql mysqli

# Installation de Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Configuration Apache
RUN a2enmod rewrite headers

# Copier les fichiers essentiels
WORKDIR /var/www/html

# Créer les dossiers nécessaires
RUN mkdir -p logs cache uploads \
    && chown -R www-data:www-data logs cache uploads \
    && chmod -R 755 logs cache uploads

# Copie du composer.json en premier pour optimiser le cache Docker
COPY composer.json composer.lock ./
# Installation des dépendances PHP
RUN composer install --no-dev --optimize-autoloader --no-interaction
# Copie du reste de l'application
COPY . .
# Script de démarrage simplifié pour test

EXPOSE 80

# Script de démarrage unifié
COPY ./docker/scripts/start-unified.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]