FROM php:8.2-apache

# Installer les extensions PHP nécessaires et nettoyer
RUN apt-get update && apt-get install -y \
    libzip-dev \
    zip \
    unzip \
    default-mysql-client \
    && docker-php-ext-install pdo pdo_mysql mysqli \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Installer Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer
RUN composer --version

# Activer mod_rewrite
RUN a2enmod rewrite

# Configurer Apache pour Railway
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf
RUN echo "Listen \${PORT}" > /etc/apache2/ports.conf
RUN sed -i 's/:80/:${PORT}/g' /etc/apache2/sites-available/000-default.conf

# Configuration du document root
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf

# Copier les fichiers
WORKDIR /var/www/html
COPY composer.json composer.lock* ./
RUN composer install --no-dev --no-interaction --optimize-autoloader

COPY . .

# Configuration des permissions
RUN chown -R www-data:www-data /var/www/html \
    && find /var/www/html -type f -exec chmod 644 {} \; 2>/dev/null || true \
    && find /var/www/html -type d -exec chmod 755 {} \; 2>/dev/null || true

# Script d'init DB
RUN echo '#!/bin/bash\n\
set -e\n\
: ${PORT:=80}\n\
: ${MYSQLHOST:?Erreur : MYSQLHOST non défini}\n\
: ${MYSQLUSER:?Erreur : MYSQLUSER non défini}\n\
: ${MYSQLPASSWORD:?Erreur : MYSQLPASSWORD non défini}\n\
: ${MYSQLDATABASE:?Erreur : MYSQLDATABASE non défini}\n\
for i in {1..60}; do\n\
  if mysql -h${MYSQLHOST} -u${MYSQLUSER} -p${MYSQLPASSWORD} -e "SELECT 1" >/dev/null 2>&1; then\n\
    echo "MySQL prêt, exécution du schéma..."\n\
    mysql -h${MYSQLHOST} -u${MYSQLUSER} -p${MYSQLPASSWORD} ${MYSQLDATABASE} < /sql/structure.sql\n\
    rm /sql/structure.sql\n\
    echo "Schéma appliqué avec succès."\n\
    break\n\
  fi\n\
  if [ $i -eq 60 ]; then\n\
    echo "Erreur : Impossible de se connecter à MySQL après 60 tentatives."\n\
    exit 1\n\
  fi\n\
  sleep 2\n\
done\n\
exec apache2-foreground' > /entrypoint.sh && chmod +x /entrypoint.sh

# Lancer le conteneur
CMD ["/entrypoint.sh"]